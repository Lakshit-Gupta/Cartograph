# Sidecar (spare machine) environment template.
# Copy to `.env.sidecar` on the spare and fill in the values extracted
# from the Pi via `sops -d --extract '["<key>"]' secrets.yaml`.
# chmod 600 the real file. Never commit it.
#
# Host = 127.0.0.1 because the autossh systemd unit on the spare forwards
# the Pi's Redis + Postgres to the spare's loopback. See
# docs/runbooks/sidecar_setup.md.

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=<sops:postgres_user>
POSTGRES_PASSWORD=<sops:postgres_password>
POSTGRES_DB=<sops:postgres_db>

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=<sops:redis_password>

LIBSODIUM_MASTER_KEY_HEX=<sops:libsodium_master_key_hex>

# Optional — uncomment only if you also tunnel port 8191 from the Pi.
# Camoufox normally solves CF challenges itself, but T1 tasks routed to
# the spare will fail without FlareSolverr access.
#FLARESOLVERR_URL=http://127.0.0.1:8191/v1

TZ=Asia/Kolkata
PYTHONUNBUFFERED=1
