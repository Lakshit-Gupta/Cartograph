# Template for secrets.yaml. After filling:
#   sops --encrypt --age <pubkey> --in-place secrets.yaml
# Commit the encrypted form. Never commit the cleartext.

postgres_user: marked
postgres_password: CHANGE_ME_STRONG_PW
postgres_db: marked

redis_password: CHANGE_ME_STRONG_REDIS_PW

openrouter_api_key: sk-or-v1-REPLACE
openrouter_model_extractor: google/gemini-flash-1.5
openrouter_model_reranker: google/gemini-flash-1.5
openrouter_model_classifier: google/gemini-flash-1.5
openrouter_model_writer: anthropic/claude-3.5-sonnet

resend_api_key: re_REPLACE
resend_from_email: applications@yourdomain.tld
resend_reply_to: you@yourdomain.tld

# Bot identity (display name = "Hop", honoring Grace Hopper).
# Set the Discord application's display name to "Hop" in the Dev Portal.
discord_bot_token: REPLACE
discord_guild_id: 0

# IMPORTANT: SOPS exec-env only exports TOP-LEVEL YAML keys as flat env vars.
# Nested maps do NOT unroll into dotted env vars. Each Discord channel ID must
# live at the top level here.
discord_channel_daily_digest: 0
discord_channel_priority_push: 0
discord_channel_fulltime: 0
discord_channel_internships: 0
discord_channel_fellowships: 0
discord_channel_freelance: 0
discord_channel_applied: 0
discord_channel_responses: 0
discord_channel_interviews: 0
discord_channel_offers: 0
discord_channel_alerts: 0
discord_channel_costs: 0
discord_channel_source_health: 0
discord_channel_bot_logs: 0

telegram_api_id: 0
telegram_api_hash: REPLACE
telegram_session_name: marked_path_freelance

reddit_client_id: REPLACE
reddit_client_secret: REPLACE
reddit_user_agent: marked-path/0.1 by u/yourhandle
# Optional. Set both to use OAuth password grant (full scope, recommended).
# Leave blank to fall back to client_credentials (public subreddit reads only).
reddit_username: ""
reddit_password: ""

r2_account_id: REPLACE
r2_access_key: REPLACE
r2_secret_key: REPLACE
r2_bucket: agent-jobs-backups

gmail_oauth_client_id: REPLACE.apps.googleusercontent.com
gmail_oauth_client_secret: REPLACE
gmail_oauth_refresh_token: REPLACE
gmail_user: you@gmail.com
gmail_worker_user: upwork-worker@yourdomain.tld
gmail_worker_app_password: REPLACE  # for IMAP IDLE workers

# Libsodium master key (32 bytes hex). Generate with:
#   python -c "import os; print(os.urandom(32).hex())"
libsodium_master_key_hex: REPLACE_64_HEX_CHARS

# Cost caps (USD)
cost_cap_daily_usd: 3.00
cost_cap_daily_kill_usd: 10.00
cost_cap_monthly_soft_usd: 30.00
cost_cap_monthly_hard_usd: 100.00

# FlareSolverr internal URL (Docker network)
flaresolverr_url: http://flaresolverr:8191

# Observability — existing Prometheus on host scrapes us at this URL
metrics_bind: 0.0.0.0:9090

# Obsidian vault dir on host (mounted into notifier container)
obsidian_vault_path: /mnt/storage/obsidian_vault
